  NIBLI :: KNOWLEDGE BASE PRELUDE :: v0.1
  lo xanri fanta bitmu — The Hallucination Firewall
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


── SELF-DESCRIPTION ──────────────────────────────────

la .nibli. cu logji ciste
⊢ GROUND  nibli ∈ logic-system
⊢         Nibli. Is. A logic system.

la .nibli. cu birti ciste
⊢ GROUND  nibli ∈ certainty-system
⊢         Nibli. Is. A certainty system.

la .nibli. cu skami ciste
⊢ GROUND  nibli ∈ computer-system
⊢         Nibli. Is. A computer system.


── FOUNDATIONAL AXIOMS ───────────────────────────────

ro lo birti cu se krinu
⊢ AXIOM   ∀x. certain(x) → justified(x)
⊢         All certainties. Have. Justification. No exceptions.

ro lo se krinu cu logji
⊢ AXIOM   ∀x. justified(x) → logical(x)
⊢         All justifications. Are. Logical. Nothing unjustified passes.

ro lo logji cu na xanri
⊢ AXIOM   ∀x. logical(x) → ¬imaginary(x)
⊢         Nothing logical. Is. Imaginary. This is the guarantee.


── ANIMAL TAXONOMY ───────────────────────────────────

ro lo gerku cu danlu
⊢ RULE    ∀x. dog(x) → animal(x)
⊢         Every dog. Is. An animal.

ro lo mlatu cu danlu
⊢ RULE    ∀x. cat(x) → animal(x)
⊢         Every cat. Is. An animal.

ro lo cipni cu danlu
⊢ RULE    ∀x. bird(x) → animal(x)
⊢         Every bird. Is. An animal.

ro lo finpe cu danlu
⊢ RULE    ∀x. fish(x) → animal(x)
⊢         Every fish. Is. An animal.

ro lo since cu danlu
⊢ RULE    ∀x. snake(x) → animal(x)
⊢         Every snake. Is. An animal.

ro lo cribe cu danlu
⊢ RULE    ∀x. bear(x) → animal(x)
⊢         Every bear. Is. An animal.

ro lo xirma cu danlu
⊢ RULE    ∀x. horse(x) → animal(x)
⊢         Every horse. Is. An animal.

ro lo bakni cu danlu
⊢ RULE    ∀x. bovine(x) → animal(x)
⊢         Every bovine. Is. An animal.

ro lo kumte cu danlu
⊢ RULE    ∀x. camel(x) → animal(x)
⊢         Every camel. Is. An animal.

ro lo ratcu cu danlu
⊢ RULE    ∀x. rat(x) → animal(x)
⊢         Every rat. Is. An animal.

ro lo mabru cu danlu
⊢ RULE    ∀x. mammal(x) → animal(x)
⊢         Every mammal. Is. An animal.

ro lo respa cu danlu
⊢ RULE    ∀x. reptile(x) → animal(x)
⊢         Every reptile. Is. An animal.

ro lo insekto cu danlu
⊢ RULE    ∀x. insect(x) → animal(x)
⊢         Every insect. Is. An animal.


── LIVING THINGS HIERARCHY ───────────────────────────

ro lo danlu cu jmive
⊢ RULE    ∀x. animal(x) → alive(x)
⊢         Every animal. Is. Alive.

ro lo tricu cu jmive
⊢ RULE    ∀x. tree(x) → alive(x)
⊢         Every tree. Is. Alive.

ro lo spati cu jmive
⊢ RULE    ∀x. plant(x) → alive(x)
⊢         Every plant. Is. Alive.

ro lo since cu jmive
⊢ RULE    ∀x. snake(x) → alive(x)
⊢         Every snake. Is. Alive. Redundant. Derivable via animal chain.


── PEOPLE TAXONOMY ───────────────────────────────────

ro lo prenu cu jmive
⊢ RULE    ∀x. person(x) → alive(x)
⊢         Every person. Is. Alive.

ro lo nanmu cu prenu
⊢ RULE    ∀x. man(x) → person(x)
⊢         Every man. Is. A person.

ro lo ninmu cu prenu
⊢ RULE    ∀x. woman(x) → person(x)
⊢         Every woman. Is. A person.

ro lo verba cu prenu
⊢ RULE    ∀x. child(x) → person(x)
⊢         Every child. Is. A person.

ro lo nakni cu nanmu
⊢ RULE    ∀x. male(x) → man(x)
⊢         Every male. Is. A man.

ro lo fetsi cu ninmu
⊢ RULE    ∀x. female(x) → woman(x)
⊢         Every female. Is. A woman.


── PERSON PROPERTIES ─────────────────────────────────

ro lo prenu cu menli se ponse
⊢ RULE    ∀x. person(x) → possesses-mind(x)
⊢         Every person. Possesses. A mind.

ro lo prenu cu bangu se ponse
⊢ RULE    ∀x. person(x) → possesses-language(x)
⊢         Every person. Possesses. Language.


── PROPERTIES AND ATTRIBUTES ─────────────────────────

ro lo barda cu se ckaji
⊢ RULE    ∀x. big(x) → has-property(x)
⊢         Bigness. Is. A property.

ro lo cmalu cu se ckaji
⊢ RULE    ∀x. small(x) → has-property(x)
⊢         Smallness. Is. A property.

ro lo sutra cu se ckaji
⊢ RULE    ∀x. fast(x) → has-property(x)
⊢         Fastness. Is. A property.

ro lo masno cu se ckaji
⊢ RULE    ∀x. slow(x) → has-property(x)
⊢         Slowness. Is. A property.

ro lo xunre cu skari
⊢ RULE    ∀x. red(x) → colour(x)
⊢         Red. Is. A colour.

ro lo blanu cu skari
⊢ RULE    ∀x. blue(x) → colour(x)
⊢         Blue. Is. A colour.

ro lo pelxu cu skari
⊢ RULE    ∀x. yellow(x) → colour(x)
⊢         Yellow. Is. A colour.

ro lo crino cu skari
⊢ RULE    ∀x. green(x) → colour(x)
⊢         Green. Is. A colour.

ro lo grusi cu skari
⊢ RULE    ∀x. grey(x) → colour(x)
⊢         Grey. Is. A colour.


